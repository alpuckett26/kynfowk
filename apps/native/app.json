{
  "expo": {
    "name": "Kynfowk",
    "slug": "kynfowk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kynfowk.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Kynfowk needs camera access for family video calls.",
        "NSMicrophoneUsageDescription": "Kynfowk needs microphone access for family video calls.",
        "NSUserNotificationsUsageDescription": "Kynfowk sends reminders before your scheduled family calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kynfowk.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#d946ef",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Kynfowk needs camera access for family video calls."
        }
      ]
    ],
    "scheme": "kynfowk",
    "experiments": {
      "typedRoutes": true
    }
  }
}
