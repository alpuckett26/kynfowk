{
  "expo": {
    "name": "Kynfowk",
    "slug": "kynfowk",
    "scheme": "kynfowk",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#fdf6ec"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kynfowk.app"
    },
    "android": {
      "package": "com.kynfowk.app",
      "adaptiveIcon": {
        "backgroundColor": "#fdf6ec"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
